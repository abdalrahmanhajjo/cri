# Backend API (same Node backend and DB as the mobile app).
# Backend runs on PORT=3000 – point the client to it.
VITE_API_URL=http://localhost:3000

# Google Maps API key (Map page + Places + MapPicker search). If you see "This page can't load Google Maps correctly":
# 1. Enable "Maps JavaScript API", "Places API", and "Geocoding API" in Google Cloud → APIs & Services → Library
# 2. Enable billing on the project (required even for free tier)
# 3. Under Credentials → your API key → Application restrictions, add HTTP referrer: http://localhost:5173/* or http://localhost:*
# VITE_GOOGLE_MAPS_API_KEY=your-maps-api-key
