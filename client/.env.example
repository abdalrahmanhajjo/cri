# =============================================================================
# Visit Tripoli — Web client (Vite)
# Copy to .env and point at the same API as the mobile app (same DB).
# Never commit real secrets.
# =============================================================================

# Canonical public origin of THIS web app (no trailing slash). Used at build time for
# <link rel="canonical">, og:url, og:image, and JSON-LD — improves Google/snippets + sharing.
# Example (match robots.txt / Search Console property): https://visit-tripoli.com
# VITE_PUBLIC_SITE_URL=https://visit-tripoli.com

# Backend base URL for API + uploads in the built app (see client/src/api/client.js).
# Local dev (npm run dev): leave EMPTY — the browser calls /api on the Vite dev server,
# which proxies to the Node API (port set by DEV_API_PROXY_TARGET below). Avoids CORS issues.
# Production — pick ONE:
# • Same server as API (Docker / SERVE_CLIENT_DIST): leave EMPTY so the browser uses /api on the same host.
# • Split hosting (e.g. Netlify + Railway): set your public API origin, e.g. https://api.yourdomain.com
VITE_API_URL=

# Dev only: where Vite proxies /api and /uploads. Must match server/.env PORT.
DEV_API_PROXY_TARGET=http://127.0.0.1:3095

# Google Sign-In (must match server GOOGLE_CLIENT_ID — OAuth 2.0 Web client id from Google Cloud).
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Google Maps (browser key — restrict by HTTP referrer to your web origin in Google Cloud).
# Same Maps key family as the app; this one is for the website only.
# VITE_GOOGLE_MAPS_API_KEY=

# Supabase Storage (production): preconnect + smaller images via /render/image (Pro+).
# Example: https://YOUR_PROJECT.supabase.co — improves LCP when place photos are on Supabase.
# VITE_SUPABASE_ORIGIN=https://YOUR_PROJECT.supabase.co
# Set to 1 only if your Supabase plan supports Storage image transforms (Pro+); otherwise images will 404.
# VITE_SUPABASE_IMAGE_TRANSFORM=1

# =============================================================================
# Not used by Vite (for reference when aligning with app env names):
# - Server-side GOOGLE_MAPS_API_KEY / GROQ / Twilio live on the API or app, not here.
# =============================================================================
