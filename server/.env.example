# =============================================================================
# Visit Tripoli — Web API (.env)
# Copy from the same secrets file as the mobile app where names match (shared DB).
# Never commit real .env — use placeholders here; keep secrets in local .env only.
# =============================================================================

# --- Core server ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# --- PostgreSQL (Supabase: Project Settings → Database) ---
# Use either "Direct connection" (Postgres on port 5432) or "Session pooler" (pooler host, often 6543).
# Password must be URL-encoded (@ ! # etc.). Do not commit real credentials.
# If you see "Circuit breaker": wrong password, paused project (Restore in dashboard), or wait ~15 min.
# "Failed to retrieve database credentials" → often paused project or Supabase incident; check status.supabase.com
#
# Direct (example shape — copy the exact string from the dashboard):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
#
# Session pooler (example):
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DB_POOL_SIZE=15

# Apply SQL in server/migrations/ (tracked in table schema_migrations). From repo root: npm run db:migrate
# Re-run every migration file: FORCE_MIGRATIONS=1 npm run db:migrate

# Non-Supabase Postgres in production: set to 1 only if you use a self-signed server cert
# DB_ACCEPT_SELF_SIGNED=1
#
# Supabase: TLS is always used. By default the API does not verify the full cert chain (fixes
# "self-signed certificate in certificate chain" on Render/Docker). To enforce verification:
# DB_VERIFY_SSL=1

# --- HTTP / proxy (Render, Fly, etc.) ---
# Trust X-Forwarded-* so rate limits and logs use the real client IP. Set TRUST_PROXY=0 if not behind a reverse proxy.
# TRUST_PROXY=1

# Stricter cap on /api/ai/* (Groq/n8n abuse). Default 24/min per IP in addition to the global /api limit.
# RATE_LIMIT_AI_PER_MIN=24

# Production: require JWT for POST /api/ai/complete (stops unauthenticated LLM credit burn)
# AI_REQUIRE_AUTH=1

# Production: allow GET /api/ai/test (otherwise 404). Leave unset in production.
# AI_TEST_ENDPOINT=1

# --- HTTP security / CORS ---
# Comma-separated browser origins, or * to allow any origin (dev / quick tests only).
# Production: list your real sites, e.g. https://visittripoli.com,https://www.visittripoli.com
# If the API serves the built SPA (SERVE_CLIENT_DIST=true), same-origin /api calls usually need no CORS tweak;
# still set CORS_ORIGIN to your public site URL(s) for mobile apps or split hosting.
CORS_ORIGIN=http://localhost:5173

# --- Google Search Console (optional; discovery / verification) ---
# Paste the content value from Search Console → Verification → HTML tag (not the whole tag).
# Injected as <meta name="google-site-verification" ...> on server-rendered HTML. Free.
# GOOGLE_SITE_VERIFICATION=your_token_from_search_console

# --- Production: serve Vite build from this process (Docker / single VM) ---
# After: npm run build --prefix client  (creates client/dist next to server/)
# SERVE_CLIENT_DIST=true

# --- Rate limits (per IP; raise if the SPA sees "Too many requests") ---
# Global /api ceiling (feed, places, user, etc. share this). Default 500/min.
# RATE_LIMIT_API_PER_MIN=500
# Auth routes: max attempts per window (default 60 per 15 min).
# RATE_LIMIT_AUTH_MAX=60
# RATE_LIMIT_AUTH_WINDOW_MIN=15
# RATE_LIMIT_ADMIN_PER_MIN=240
# RATE_LIMIT_BUSINESS_PER_MIN=300
# RATE_LIMIT_COUPONS_PER_MIN=120

# --- Request body size for JSON (feed posts, admin saves, etc.) ---
# JSON_BODY_LIMIT=512kb

# Check-in: max distance from place coordinates (meters). Matches typical mobile geofence. Set to 0 to disable (local dev only).
# CHECKIN_MAX_DISTANCE_METERS=400

# --- Optional: run pending SQL in server/migrations/ on your Postgres (e.g. 010_place_messaging_blocks.sql) ---

# --- Auth & admin (same JWT_SECRET as app backend if you share tokens) ---
JWT_SECRET=minimum-32-character-secret-change-in-production
# Optional: comma-separated emails allowed as admin without is_admin in DB (bootstrap only)
# ADMIN_EMAILS=you@example.com

# --- Public URLs ---
# Vite dev server URL (shown in startup logs). Production: your deployed web app origin.
CLIENT_DEV_URL=http://localhost:5173
# Optional: links inside OTP emails (login). Also accepts RESET_PASSWORD_BASE_URL or CLIENT_URL.
# PUBLIC_CLIENT_URL=https://your-site.com
# APP_URL=http://localhost:3000

# --- Uploads & media ---
# Public base URL for place images when not using Supabase Storage (optional)
# UPLOADS_BASE_URL=https://api.yoursite.com

# --- Supabase (Storage uploads — same project as app) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Service role / secret key (dashboard → API). Either name works:
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SERVICE_KEY=

# --- Email (same SMTP as mobile app — Gmail example) ---
APP_NAME=Visit Tripoli
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From header: any of these (app often uses SMTP_FROM)
# MAIL_FROM=Visit Tripoli <noreply@yourdomain.com>
# SMTP_FROM=noreply@yourdomain.com

# --- Dev: forgot-password logs the code to the API console if email fails (never returned in JSON) ---
# ENABLE_DEV_CODE=true

# =============================================================================
# Variables below are common in the mobile app .env but NOT read by this Node API
# (you can keep them here when copying one shared env file — they are ignored).
# =============================================================================
# ADMIN_SECRET=
# GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=
# RESET_PASSWORD_BASE_URL=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# GOOGLE_MAPS_API_KEY=
#
# --- AI trip planner (same as VisitTripoliApp — https://github.com/abdalrahmanhajjo/VisitTripoliApp) ---
# Free Groq: https://console.groq.com → API key (gsk_...). Optional: GROQ_MODEL=llama-3.1-8b-instant
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# Or use n8n webhook instead of Groq:
# N8N_WEBHOOK_URL=
# ALLOW_INSECURE_TLS=
