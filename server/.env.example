# Same database as the mobile app (Figma1). Use the same DATABASE_URL (e.g. Supabase).
# Copy this to .env and fill in values.

PORT=3095

# Postgres connection (same DB as Tripoli Explorer mobile app).
# Supabase: Project Settings -> Database -> Connection string (URI, Session pooler).
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/tripoli_explorer

# JWT secret (min 32 chars in production). Use same as mobile backend if you want tokens to work across both.
JWT_SECRET=minimum-32-character-secret-change-this

# CORS: allow web client origin(s), comma-separated. Required in production.
# Local: http://localhost:5173
# Production: https://yoursite.com,https://www.yoursite.com
CORS_ORIGIN=http://localhost:5173

# When deployed: set to your public API URL so image URLs work (e.g. https://api.yoursite.com).
# UPLOADS_BASE_URL=https://your-api-domain.com

# Supabase Storage (for image uploads – stored in cloud, not localhost).
# Get from Supabase Dashboard: Project Settings → API.
# SUPABASE_URL=https://your-project-ref.supabase.co
# Use the service_role JWT from "Legacy API Keys" tab (long key starting with eyJ).
# Or use a secret key (sb_secret_...) from "Secret keys" section.
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...
# Create a public bucket named "place-images" in Storage if it doesn't exist.

# Optional: Supabase self-signed cert in dev.
# DB_ACCEPT_SELF_SIGNED=1

# Development: set to true to always return the reset code on the forgot-password page (so you can reset without email).
# ENABLE_DEV_CODE=true

# Optional: SMTP for real email (forgot password, verification). If not set, codes are logged to console only.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# MAIL_FROM=Visit Tripoli <noreply@yourdomain.com>
