# =============================================================================
# Visit Tripoli — Web API (.env)
# Copy from the same secrets file as the mobile app where names match (shared DB).
# Never commit real .env — use placeholders here; keep secrets in local .env only.
# =============================================================================

# --- Core server ---
NODE_ENV=production
PORT=3095
HOST=0.0.0.0
# Comma-separated origins for CORS, e.g. https://visittripoli.com
CORS_ORIGIN=http://localhost:5173
# Required for secure authentication
JWT_SECRET=minimum-32-character-secret-change-in-production

# JSON logs (one object per line) for aggregators; omit for plain console text
# LOG_FORMAT=json
# Log DB queries slower than this (ms); 0 disables (default 750)
# DB_SLOW_QUERY_MS=750

# Optional: Sentry error monitoring (https://sentry.io)
# Omit SENTRY_DSN or set SENTRY_ENABLED=off to keep Sentry off.
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_ENABLED=off
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=tripoli-api@1.0.0

# --- ImageKit (Media Storage Pivot) ---
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
# Optional: folder name in ImageKit dashboard
IMAGEKIT_FOLDER=/tripoli-explorer

# --- MongoDB (Database & Legacy GridFS) ---
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/
MONGODB_URI=
# Optional override if the URI path does not include the DB name:
# MONGODB_DB_NAME=visittripoli

SMTP_USER=
SMTP_PASS=
# From header: any of these (app often uses SMTP_FROM)
# MAIL_FROM=Visit Tripoli <noreply@yourdomain.com>
# SMTP_FROM=noreply@yourdomain.com

# --- Stripe: paid place sponsorship (Business → Sponsorship) ---
# Requires migration 029_sponsorship_purchases.sql. Webhook path: POST /api/webhooks/stripe (raw body — mounted before JSON parser).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: use a fixed Price in Stripe Dashboard instead of site-settings cents:
# STRIPE_PRICE_ID=price_...
# Default rank for paid rows (lower = higher in list). Admins can change per row.
# SPONSORSHIP_PAID_DEFAULT_RANK=500

# --- Dev: forgot-password logs the code to the API console if email fails (never returned in JSON) ---
# ENABLE_DEV_CODE=true

# =============================================================================
# Variables below are common in the mobile app .env but NOT read by this Node API
# (you can keep them here when copying one shared env file — they are ignored).
# =============================================================================
# ADMIN_SECRET=
# GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=
# RESET_PASSWORD_BASE_URL=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# GOOGLE_MAPS_API_KEY=
#
# --- AI trip planner (same as VisitTripoliApp — https://github.com/abdalrahmanhajjo/VisitTripoliApp) ---
# Free Groq: https://console.groq.com → API key (gsk_...). Optional: GROQ_MODEL=llama-3.1-8b-instant
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# Or use n8n webhook instead of Groq:
# N8N_WEBHOOK_URL=
# ALLOW_INSECURE_TLS=
